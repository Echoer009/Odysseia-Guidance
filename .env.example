# .env.example - 环境变量示例文件
# 将此文件复制为 .env 并填入你的实际值。
# 运行 bash setup.sh 可自动生成交互式配置

# --- 实例配置 ---
# 用于在一台服务器上运行多个类脑娘实例时区分不同实例
# Docker 容器名称和网络名称会以此为前缀
INSTANCE_NAME=odysseia
# 数据库主机地址（Docker 环境下使用 compose 服务名 "db"，本地开发使用 "localhost"）
DB_HOST=db

# 你的 Discord 机器人令牌
DISCORD_TOKEN="YOUR_DISCORD_TOKEN_HERE"

# (可选) 用于在开发时快速同步斜杠命令的服务器（公会）ID
# 如果留空，命令将进行全局同步（可能需要长达一小时才能生效）
GUILD_ID="YOUR_DEVELOPMENT_GUILD_ID_HERE"

# --- 权限控制 ---
# 拥有此命令访问权限的开发者用户ID，多个ID请用逗号分隔
DEVELOPER_USER_IDS="YOUR_USER_ID_1,YOUR_USER_ID_2"

# 拥有此命令访问权限的身份组ID，多个ID请用逗号分隔
ADMIN_ROLE_IDS="YOUR_ROLE_ID_1,YOUR_ROLE_ID_2"

# --- 向量模式配置 ---
# none: 无向量直接聊天（不使用 RAG 检索）
# api: API 向量（使用 Gemini Embedding API，需要下方 GOOGLE_API_KEYS_LIST）
# local: 本地向量（使用 Ollama 本地模型）
VECTOR_MODE=none

# Gemini API 密钥 (用于 API 向量模式的 RAG 检索)
# 多个密钥请直接换行，并用英文双引号 "..." 将所有密钥包裹起来
GOOGLE_API_KEYS_LIST="
YOUR_GEMINI_API_KEY_1
YOUR_GEMINI_API_KEY_2
"

# Ollama 模型配置（仅在 VECTOR_MODE=local 时有效）
OLLAMA_MODEL="qwen3-embedding:0.6b"
OLLAMA_VISION_MODEL="qwen3.5:0.8b"

# --- 功能开关 ---
# 是否启用聊天功能 (True/False)
CHAT_ENABLED=True

# 是否记录AI完整的上下文日志 (true/false)
LOG_AI_FULL_CONTEXT=true

# --- 工具加载器配置 ---
# 禁用的工具模块列表（文件名，不含.py扩展名），多个用逗号分隔
DISABLED_TOOLS="get_yearly_summary"

# --- 类脑币系统 ---
# 在指定服务器发帖可获得奖励的服务器ID，多个用逗号隔开
COIN_REWARD_GUILD_IDS="YOUR_GUILD_ID_1,YOUR_GUILD_ID_2"

# --- 论坛帖子语义搜索 ---
# 需要进行RAG索引的论坛频道ID，多个用逗号隔开
FORUM_SEARCH_CHANNEL_IDS="YOUR_FORUM_CHANNEL_ID_1,YOUR_FORUM_CHANNEL_ID_2"

# --- PostgreSQL 数据库配置 ---
POSTGRES_DB="your_database_name"
POSTGRES_USER="your_username"
POSTGRES_PASSWORD="your_password"
DB_PORT=5432

# --- SearXNG 联网搜索配置 ---
# SearXNG 搜索引擎地址（Docker 内部网络使用容器名，本地开发使用 localhost）
# Docker 环境: http://searxng:8080
# 本地开发: http://localhost:8888
SEARXNG_URL="http://searxng:8080"

# 搜索结果最大返回数量（默认 5）
WEB_SEARCH_MAX_RESULTS=5
# 搜索请求超时秒数（默认 10）
WEB_SEARCH_TIMEOUT=10
# 网页抓取超时秒数（默认 15）
WEB_SCRAPE_TIMEOUT=15
# 网页抓取最大字符数（默认 5000）
WEB_SCRAPE_MAX_LENGTH=5000

# --- GPT Image 2 投喂生图 ---
GPT_IMAGE_API_KEY="sk-xxx"
GPT_IMAGE_BASE_URL="https://api.openai.com/v1"
GPT_IMAGE_MODEL="gpt-image-2"
